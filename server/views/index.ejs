<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      body { margin: 0; font-family: system-ui, sans-serif; background: #f8f3ea; color: #55534c; padding: 32px; }
      main { max-width: 720px; margin: 0 auto; background: #fffdf8; padding: 24px; border-radius: 24px; border: 1px solid #efe4d6; }
      a { display: inline-block; margin-top: 12px; background: #a8b193; color: white; padding: 12px 16px; border-radius: 14px; text-decoration: none; font-weight: 700; }
      pre { background: white; padding: 16px; border-radius: 16px; overflow: auto; border: 1px solid #efe4d6; }
    </style>
  </head>
  <body>
    <main>
      <h1>Camelio Server</h1>
      <p>Statut : <strong><%= authenticated ? "connecté" : "non connecté" %></strong></p>
      <% if (authenticated) { %>
        <pre><%= JSON.stringify(user, null, 2) %></pre>
        <a href="/logout">Se déconnecter</a>
      <% } else { %>
        <a href="/login">Connexion avec Cognito</a>
      <% } %>
    </main>
  </body>
</html>
